# Clerk authentication (sign up / sign in).
# 1. Create a free app at https://dashboard.clerk.com
# 2. Copy the "Publishable key" (starts with pk_test_ or pk_live_)
# 3. Create a local `.env` file and set it:
#
#   VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
#
# Without this key, the game still runs — auth UI is just hidden.
VITE_CLERK_PUBLISHABLE_KEY=
